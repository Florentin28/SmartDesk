@page "/tickets" 
@rendermode InteractiveServer 

@using SmartDesk.Models 
@using SmartDesk.Data 
@using Microsoft.EntityFrameworkCore 
@inject SmartDesk.Services.AuthService Auth
@inject NavigationManager Navigation
@inject AppDbContext Context 

<div class="container mt-4">
    
    @if (!Auth.IsLoggedIn)
    {
        <div class="alert alert-danger text-center">
            <h5><i class="bi bi-exclamation-triangle-fill"></i> Access Denied</h5>
            <p>You must be logged in to view this page.</p>
            <a href="/" class="btn btn-danger">Go to Login</a>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-4 bg-light p-3 rounded shadow-sm">
            <div>
                <h2 class="text-primary fw-bold m-0"><i class="bi bi-ticket-perforated"></i> SmartDesk</h2>
                <small class="text-muted">Logged in as: <strong class="text-dark">@Auth.CurrentEmail</strong> (@(Auth.IsTechnician ? "Technician" : "Employee"))</small>
            </div>
            
            <button @onclick="Logout" class="btn btn-outline-danger btn-sm fw-bold">
                <i class="bi bi-box-arrow-left"></i> Logout
            </button>
        </div>

        <div class="row g-4">
            @if (!Auth.IsTechnician)
            {
                <div class="col-lg-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-primary text-white fw-bold py-3">
                            Create a New Ticket
                        </div>
                        <div class="card-body p-4">
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Problem Title</label>
                                <input @bind="newTitle" class="form-control form-control-lg" placeholder="e.g., Printer offline" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Detailed Description</label>
                                <textarea @bind="newDescription" class="form-control" rows="4" placeholder="Describe your issue here..."></textarea>
                            </div>
                            <button @onclick="CreateTicket" class="btn btn-primary w-100 btn-lg fw-bold mt-2">
                                Submit Ticket
                            </button>
                        </div>
                    </div>
                </div>
            }

            @* GRILLE DYNAMIQUE *@
            <div class="@(Auth.IsTechnician ? "col-12" : "col-lg-8")">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-dark text-white fw-bold py-3 d-flex justify-content-between align-items-center">
                        <span>@(Auth.IsTechnician ? "Technician Console: All Tickets" : "Your Submitted Tickets")</span>
                        <span class="badge bg-secondary">@(filteredTickets?.Count ?? 0) displayed</span>
                    </div>
                    
                    <div class="card-body p-0">
                        @if (Auth.IsTechnician)
                        {
                            <div class="bg-light p-3 border-bottom d-flex gap-2">
                                <button @onclick='() => ChangeFilter("All")' class='btn btn-sm @(selectedFilter == "All" ? "btn-dark" : "btn-outline-dark") fw-semibold'>All</button>
                                <button @onclick='() => ChangeFilter("New")' class='btn btn-sm @(selectedFilter == "New" ? "btn-info" : "btn-outline-info") fw-semibold'>New</button>
                                <button @onclick='() => ChangeFilter("In Progress")' class='btn btn-sm @(selectedFilter == "In Progress" ? "btn-warning" : "btn-outline-warning") fw-semibold'>In Progress</button>
                                <button @onclick='() => ChangeFilter("Resolved")' class='btn btn-sm @(selectedFilter == "Resolved" ? "btn-success" : "btn-outline-success") fw-semibold'>Resolved</button>
                            </div>
                        }

                        @if (filteredTickets == null)
                        {
                            <div class="p-4 text-center">
                                <div class="spinner-border text-primary" role="status"></div>
                            </div>
                        }
                        else if (!filteredTickets.Any())
                        {
                            <div class="p-5 text-center text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                                <span>No tickets found.</span>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width: 8%">ID</th>
                                            <th style="width: 47%">Ticket Details</th>
                                            <th style="width: 15%">Status</th>
                                            @if (Auth.IsTechnician)
                                            {
                                                <th style="width: 15%">Change Priority</th>
                                                <th style="width: 15%">Change Status</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var ticket in filteredTickets)
                                        {
                                            <tr class="@GetRowPriorityClass(ticket.Priority)">
                                                <td><span class="text-muted fw-bold">#@ticket.Id</span></td>
                                                <td>
                                                    <div class="fw-bold text-dark">@ticket.Title</div>
                                                    <small class="text-muted d-block text-wrap">@ticket.Description</small>
                                                    <small class="text-muted d-block mt-1" style="font-size: 0.75rem;">
                                                        <i class="bi bi-clock"></i> @ticket.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm") 
                                                        @if (Auth.IsTechnician)
                                                        {
                                                            <span> | <i class="bi bi-person"></i> By: @ticket.SubmittedBy</span>
                                                        }
                                                    </small>
                                                </td>
                                                <td>
                                                    <span class="badge @GetStatusBadgeClass(ticket.Status) fw-bold px-2 py-1">
                                                        @ticket.Status
                                                    </span>
                                                </td>
                                                
                                                @if (Auth.IsTechnician)
                                                {
                                                    <td>
                                                        <select value="@ticket.Priority" @onchange="(e) => UpdateTicketPriority(ticket, e.Value?.ToString())" class="form-select form-select-sm fw-semibold">
                                                            <option value="Low">Low</option>
                                                            <option value="Medium">Medium</option>
                                                            <option value="High">High</option>
                                                        </select>
                                                    </td>
                                                    <td>
                                                        <select value="@ticket.Status" @onchange="(e) => UpdateTicketStatus(ticket, e.Value?.ToString())" class="form-select form-select-sm fw-semibold">
                                                            <option value="New">New</option>
                                                            <option value="In Progress">In Progress</option>
                                                            <option value="Resolved">Resolved</option>
                                                        </select>
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Ticket>? allTickets; 
    private List<Ticket>? filteredTickets; 
    
    private string newTitle = string.Empty; 
    private string newDescription = string.Empty; 
    private string selectedFilter = "All";

    protected override async Task OnInitializedAsync() => await LoadTickets(); 

    private async Task LoadTickets()
    {
        allTickets = await Context.Tickets.ToListAsync(); 
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (allTickets == null) return;

        if (Auth.IsTechnician)
        {
            // Le technicien voit tout, mais peut filtrer par l'état des boutons (All, New, etc.)
            if (selectedFilter == "All") filteredTickets = allTickets;
            else filteredTickets = allTickets.Where(t => t.Status == selectedFilter).ToList();
        }
        else
        {
            // CHANGEMENT ICI : L'employé ne voit STRICTEMENT que les tickets liés à son email de session
            filteredTickets = allTickets.Where(t => t.SubmittedBy == Auth.CurrentEmail).ToList();
        }
    }

    private void ChangeFilter(string filterName)
    {
        selectedFilter = filterName;
        ApplyFilter();
    }

    private async Task CreateTicket()
    {
        if (string.IsNullOrWhiteSpace(newTitle)) return; 

        // CHANGEMENT ICI : On associe l'email de la personne connectée au ticket créé
        var ticket = new Ticket 
        { 
            Title = newTitle, 
            Description = newDescription,
            SubmittedBy = Auth.CurrentEmail 
        };
        
        Context.Tickets.Add(ticket); 
        await Context.SaveChangesAsync(); 

        newTitle = string.Empty;
        newDescription = string.Empty;
        await LoadTickets();
    }

    private async Task UpdateTicketStatus(Ticket ticket, string? nextStatus)
    {
        if (string.IsNullOrEmpty(nextStatus)) return;
        ticket.Status = nextStatus;
        await Context.SaveChangesAsync();
        await LoadTickets(); 
    }

    private async Task UpdateTicketPriority(Ticket ticket, string? nextPriority)
    {
        if (string.IsNullOrEmpty(nextPriority)) return;
        ticket.Priority = nextPriority;
        await Context.SaveChangesAsync();
        await LoadTickets(); 
    }

    private void Logout()
    {
        Auth.Logout();
        Navigation.NavigateTo("/");
    }

    private string GetStatusBadgeClass(string status) => status switch
    {
        "New" => "bg-info text-dark",
        "In Progress" => "bg-warning text-dark",
        "Resolved" => "bg-success text-white",
        _ => "bg-secondary text-white"
    };

    private string GetRowPriorityClass(string priority) => priority switch
    {
        "Low" => "table-primary",    
        "High" => "table-danger",    
        _ => ""                      
    };
}
@* Nom de la page *@
@page "/tickets" 

@* Met a jour automatiquement la page *@
@rendermode InteractiveServer 

@using SmartDesk.Models 
@using SmartDesk.Data 
@using Microsoft.EntityFrameworkCore

@* Inject the database context *@
@inject AppDbContext Context

<div class="container mt-4">
    <!-- En-tête principal -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold m-0"><i class="bi bi-ticket-perforated"></i> SmartDesk</h2>
        <span class="badge bg-secondary fs-6">
            @(tickets?.Count ?? 0) Ticket(s)
        </span>
    </div>

    <div class="row g-4">
        <!-- COLONNE GAUCHE : Formulaire de création -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white fw-bold py-3">
                    Create a New Ticket
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Problem Title</label>
                        <input @bind="newTitle" class="form-control form-control-lg" placeholder="e.g., Printer offline" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Detailed Description</label>
                        <textarea @bind="newDescription" class="form-control" rows="4" placeholder="Describe your issue here..."></textarea>
                    </div>
                    <button @onclick="CreateTicket" class="btn btn-primary w-100 btn-lg fw-bold mt-2">
                        Submit Ticket
                    </button>
                </div>
            </div>
        </div>

        <!-- COLONNE DROITE : Liste des tickets -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light fw-bold py-3">
                    All Active Tickets
                </div>
                <div class="card-body p-0">
                    @if (tickets == null)
                    {
                        <div class="p-4 text-center">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="text-muted mt-2 mb-0">Loading data...</p>
                        </div>
                    }
                    else if (!tickets.Any())
                    {
                        <div class="p-5 text-center text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                            <span>No tickets found in the database. Everything is running smoothly!</span>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 10%">ID</th>
                                        <th style="width: 45%">Ticket Details</th>
                                        <th style="width: 20%">Status</th>
                                        <th style="width: 25%">Created At</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ticket in tickets)
                                    {
                                        <tr>
                                            <td><span class="text-muted fw-bold">#@ticket.Id</span></td>
                                            <td>
                                                <div class="fw-bold text-dark">@ticket.Title</div>
                                                <small class="text-muted text-wrap d-block" style="max-width: 300px;">@ticket.Description</small>
                                            </td>
                                            <td>
                                                @* Petit badge dynamique selon le statut *@
                                                <span class="badge @(ticket.Status == "New" ? "bg-info text-dark" : "bg-warning text-dark") fw-bold px-2 py-1">
                                                    @ticket.Status
                                                </span>
                                            </td>
                                            <td>
                                                <small class="text-muted">
                                                    @ticket.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                                </small>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Ticket>? tickets; // Liste des tickets récupérés depuis la BDD
    private string newTitle = string.Empty; // Titre du nouveau ticket à créer
    private string newDescription = string.Empty; // Description du nouveau ticket à créer

    // Cette méthode se lance automatiquement quand la page s'affiche à l'écran
    protected override async Task OnInitializedAsync() // Méthode pour actualiser la liste à l'ouverture de la page
    {
        await LoadTickets(); // appelle la méthode LoadTickets pour récupérer les tickets depuis la BDD
    }

    // Va chercher les tickets dans la BDD
    private async Task LoadTickets()
    {
        tickets = await Context.Tickets.ToListAsync(); // Va chercher le contenu de la table tickets et les transforme en liste pour l'afficher à l'écran
    }

    // Crée un ticket et l'enregistre dans la BDD
    private async Task CreateTicket()
    {
        if (string.IsNullOrWhiteSpace(newTitle)) return; // Sécurité si le champ est vide on n'ajout pas de ticket vide

        // L'Id, le Status ("New") et la Date sont générés automatiquement par le système
        var ticket = new Ticket 
        {
            Title = newTitle,
            Description = newDescription
        };

        Context.Tickets.Add(ticket); // On dépose l'objet dans la file d'attente de la BDD
        await Context.SaveChangesAsync(); // Il l'enregistre physiquement dans la BDD (l'ID est généré ici)

        // On vide les champs du formulaire après l'envoi
        newTitle = string.Empty;
        newDescription = string.Empty;

        // On rafraîchit la liste à l'écran
        await LoadTickets();
    }
}